{
  "type": "panel",
  "i18n": true,
  "items": {
    "intro": {
      "type": "infoBox",
      "text": "Enter the CLAGE Home Server address and its API credentials. All three fields are required.",
      "newLine": true,
      "xs": 12
    },
    "adresse": {
      "type": "ip",
      "label": "CLAGE Home Server IP address",
      "listenOnAllPorts": false,
      "onlyIp4": true,
      "noInternal": false,
      "xs": 12,
      "sm": 6,
      "md": 6,
      "lg": 6,
      "xl": 6
    },
    "port": {
      "type": "text",
      "label": "API user name",
      "help": "The historical configuration key is named port, but this value is the user name.",
      "xs": 12,
      "sm": 6,
      "md": 6,
      "lg": 6,
      "xl": 6
    },
    "apiKey": {
      "type": "password",
      "label": "API password",
      "visible": true,
      "xs": 12,
      "sm": 6,
      "md": 6,
      "lg": 6,
      "xl": 6
    },
    "advancedInfo": {
      "type": "header",
      "text": "Polling",
      "size": 2,
      "newLine": true,
      "xs": 12
    },
    "activePollMs": {
      "type": "number",
      "label": "Active-device interval (ms)",
      "min": 1000,
      "max": 3600000,
      "xs": 12,
      "sm": 6,
      "md": 3,
      "lg": 3,
      "xl": 3
    },
    "idlePollMs": {
      "type": "number",
      "label": "Idle-device interval (ms)",
      "min": 5000,
      "max": 3600000,
      "xs": 12,
      "sm": 6,
      "md": 3,
      "lg": 3,
      "xl": 3
    },
    "detailsPollMs": {
      "type": "number",
      "label": "History/setup interval (ms)",
      "min": 60000,
      "max": 3600000,
      "xs": 12,
      "sm": 6,
      "md": 3,
      "lg": 3,
      "xl": 3
    },
    "historyDays": {
      "type": "number",
      "label": "Consumption history (days)",
      "min": 1,
      "xs": 12,
      "sm": 6,
      "md": 3,
      "lg": 3,
      "xl": 3
    },
    "longPolling": {
      "type": "checkbox",
      "label": "Use device-list long polling",
      "xs": 12,
      "sm": 6,
      "md": 3,
      "lg": 3,
      "xl": 3
    }
  }
}
